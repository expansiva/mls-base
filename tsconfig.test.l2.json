{
  "compilerOptions": {
    "target": "es2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["dom", "ES2022", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": [
    "mls-*/l2/**/*.ts",
    "test/**/*.ts",
    "types/mls.d.ts",
    "types/monaco.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts",
    "./mls-102030/**/*"
  ]
}