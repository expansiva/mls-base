{
    "name": "repos",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "postinstall": "node runInstall.js",
        "updateProjects": "node runInstall.js update",
        "build": "pnpm build:frontend && pnpm build:backend",
        "build:frontend": "tsc -p tsconfig.frontend.json",
        "build:backend": "tsc -p tsconfig.backend.json",
        "build:watch": "tsc -p tsconfig.frontend.json --watch & tsc -p tsconfig.backend.json --watch",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.922.0",
        "@aws-sdk/lib-dynamodb": "^3.922.0",
        "fastify": "^5.6.1",
        "lit": "^3.3.2",
        "pg": "^8.16.3",
         "adm-zip": "0.5.16",
        "less": "^4.2.0",
        "esbuild": "^0.27.2",
        "mls-ci": "git+https://github.com/expansiva/mls-ci.git",
        "node-fetch": "^2.7.0",
        "typescript": "^5.5.3"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.2",
        "@types/node": "^24.5.2",
        "@types/pg": "^8.18.0",
        "esbuild": "^0.27.4",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.9.2",
        "mls-ci": "git+https://github.com/expansiva/mls-ci.git",
        "node-fetch": "^2.7.0",
        "less": "^4.6.4",
        "adm-zip": "0.5.16"
    }
}