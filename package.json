{
    "name": "repos",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "install:dev": "node scripts/install/runInstallDevs.js",
        "postInstall": "node scripts/install/runInstallLibs.js",
        "build": "node scripts/runtime/addNewVersion.mjs",
        "compile": "node scripts/build.mjs",
        "build:server": "node scripts/build.mjs --client 102048 --only server",
        "build:web": "node scripts/build.mjs --only web",
        "build:frontend": "tsc -p tsconfig.frontend.json",
        "build:backend": "tsc -p tsconfig.backend.json",
        "build:watch": "tsc -p tsconfig.frontend.json --watch & tsc -p tsconfig.backend.json --watch",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "processCss": "node scripts/processCssAfterCompile.mjs --dist dist",
        "compile:local": "tsc && node scripts/processCssAfterCompile.mjs --dist dist",
        "materializeL1": "tsx mls-102021/l1/cbMaterializeCli/nodejsMaterializeL1.ts 102048 cafeFlow --check --force",
        "materializeL2": "tsx mls-102020/l2/agentChangeFrontend/nodejsMaterializeL2.ts -- 102051 cafeFlow --force",
        "migrate": "node scripts/runMigrate.mjs",

        "publish": "pnpm run buildClientObj && node scripts/runPublishMlsBase.mjs",

        "publish:initial": "node scripts/runPublishMlsBase.mjs --initial",
        "buildClientObj": "node scripts/buildClientObj.mjs  --client 102051",
        "test": "node scripts/run-tests.mjs --all",
        "test:102020": "node scripts/run-tests.mjs 102020",
        "test:l1": "node scripts/run-tests.mjs --all l1",
        "test:l2": "node scripts/run-tests.mjs --all l2"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.922.0",
        "@aws-sdk/lib-dynamodb": "^3.922.0",
        "adm-zip": "0.5.16",
        "esbuild": "^0.27.2",
        "fastify": "^5.6.1",
        "less": "^4.2.0",
        "lit": "^3.3.2",
        "mls-ci": "git+https://github.com/expansiva/mls-ci.git",
        "node-fetch": "^2.7.0",
        "pg": "^8.16.3",
        "typescript": "^5.5.3"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.2",
        "@types/node": "^24.5.2",
        "@types/pg": "^8.18.0",
        "adm-zip": "0.5.16",
        "esbuild": "^0.27.4",
        "less": "^4.6.4",
        "mls-ci": "git+https://github.com/expansiva/mls-ci.git",
        "node-fetch": "^2.7.0",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.19.0",
        "typescript": "^5.9.2"
    }
}
